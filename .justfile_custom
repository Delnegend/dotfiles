	sudo chmod 700 ~/.ssh
	sudo chmod 600 ~/.ssh/*
	sudo chmod 644 ~/.ssh/*.pub
	sudo chmod 644 ~/.ssh/known_hosts
	sudo chmod 644 ~/.ssh/config

transcode codec input:
	#!/bin/bash
	codec="{{ codec }}"
	input="{{ input }}"

	echo "Transcoding file '$input' to codec '$codec'..."
	if [[ $codec == "avif" ]]; then
		ffmpeg -i "$input" -c:v libaom-av1 -crf 24 -cpu-used 5 "${input%.*}.avif"
	elif [[ $codec == "vp9" ]]; then
		ffmpeg -i "$input" -c:v libvpx-vp9 -crf 26 -b:v 0 "${input%.*}.webm"
	elif [[ $codec == "av1" ]]; then
		ffmpeg -i "$input" -c:v libsvtav1 -crf 26 -b:v 0 "${input%.*}.mp4"
	else
		echo "Unsupported codec. Please use 'avif', 'vp9', or 'av1'."
		exit 1
	fi

thumb file:
	#!/bin/bash
	FILE="$1"

	ffmpeg -i "$FILE" -map 0 -map 0 -filter:0 "scale=300:200:force_original_aspect_ratio=decrease,pad=300:200:(ow-iw)/2:(oh-ih)/2:color=0x00000000,format=yuv420p" -filter:1 "scale=300:200:force_original_aspect_ratio=decrease,pad=300:200:(ow-iw)/2:(oh-ih)/2:color=0x00000000,format=yuva444p,alphaextract" -crf 22 -cpu-used 5 "${FILE%.*}.avif"

update-static:
	#!/bin/bash

	get_latest_github_ver() {
		curl -sL -w "%{url_effective}" "https://github.com/$1/releases/latest" -o /dev/null | grep -o '[^/]*$' | sed 's/^v//' | head -n 1
	}


	LIBJXL_CURR_VER=$(cjxl --version | grep -oP '\d+\.\d+\.\d+' | head -n 1)
	LIBJXL_LATEST_VER=$(get_latest_github_ver libjxl/libjxl)
	if [ "$LIBJXL_CURR_VER" != "$LIBJXL_LATEST_VER" ]; then
		echo "Updating libjxl from $LIBJXL_CURR_VER to $LIBJXL_LATEST_VER"
		wget -q -P /tmp "https://github.com/libjxl/libjxl/releases/download/v$LIBJXL_LATEST_VER/libjxl-$LIBJXL_LATEST_VER-linux-x86_64.tar.gz"
		tar -xzf /tmp/libjxl-$LIBJXL_LATEST_VER-linux-x86_64.tar.gz -C /home/$(whoami)/Apps cjxl cjxl
		tar -xzf /tmp/libjxl-$LIBJXL_LATEST_VER-linux-x86_64.tar.gz -C /home/$(whoami)/Apps djxl djxl
		rm -f /tmp/libjxl-$LIBJXL_LATEST_VER-linux-x86_64.tar.gz
	else
		echo "libjxl is already up to date ($LIBJXL_CURR_VER)"
	fi

sunshine state='start':
	#!/usr/bin/bash

	SUNSHINE_BIN=$(readlink -f "$(which sunshine 2>/dev/null)" 2>/dev/null || echo "")

	if [[ -n "$SUNSHINE_BIN" ]] && ! getcap "$SUNSHINE_BIN" 2>/dev/null | grep -q cap_sys_admin; then
		echo "Missing CAP_SYS_ADMIN on sunshine binary, granting..."
		sudo setcap cap_sys_admin+ep "$SUNSHINE_BIN"
	fi

	START_KEYWORDS=(start restart enable 1 on)
	STOP_KEYWORDS=(stop disable 0 off)

	if [[ " ${START_KEYWORDS[*]} " == *" {{state}} "* ]]; then
		systemctl --user start sunshine
		echo "Sunshine is now STARTED"
	elif [[ " ${STOP_KEYWORDS[*]} " == *" {{state}} "* ]]; then
		systemctl --user stop sunshine
		echo "Sunshine is now STOPPED"
	else
		echo "Invalid state. Use 'start' or 'stop'."
		exit 1
	fi

rdp state='start':
	#!/usr/bin/bash

	START_KEYWORDS=(start restart enable 1 on)
	STOP_KEYWORDS=(stop disable 0 off)

	systemctl --user daemon-reload
	if [[ " ${START_KEYWORDS[*]} " == *" {{state}} "* ]]; then
		systemctl --user start app-org.kde.krdpserver.service
		echo "app-org.kde.krdpserver.service is now STARTED"
	elif [[ " ${STOP_KEYWORDS[*]} " == *" {{state}} "* ]]; then
		systemctl --user stop app-org.kde.krdpserver.service
		echo "app-org.kde.krdpserver.service is now STOPPED"
	else
		echo "Invalid state. Use 'start' or 'stop'."
		exit 1
	fi

unlock:
	#!/usr/bin/bash
	set -euo pipefail

	CONF_DIR="/etc/plasmalogin.conf.d"
	PAM_DIR="/etc/pam.d"

	sudo bash -c "
		rm -f '$CONF_DIR/99-plasma-setup.conf'
		printf '[Autologin]\nUser=lava\nSession=plasma\n' > '$CONF_DIR/99-autologin.conf'
		printf '#%%PAM-1.0\nauth        sufficient   pam_permit.so\naccount     sufficient   pam_permit.so\npassword    sufficient   pam_permit.so\nsession     include      password-auth\n' > '$PAM_DIR/plasmalogin'
		printf '#%%PAM-1.0\nauth        sufficient   pam_permit.so\naccount     sufficient   pam_permit.so\npassword    sufficient   pam_permit.so\nsession     include      password-auth\n' > '$PAM_DIR/plasmalogin-autologin'
		printf '#%%PAM-1.0\nauth        include      password-auth\naccount     include      password-auth\npassword    include      password-auth\nsession     include      password-auth\n' > '$PAM_DIR/plasmalogin-greeter'
		systemctl restart plasmalogin
	"

	echo "Waiting for session..."
	for i in {1..30}; do
		if loginctl list-sessions 2>/dev/null | grep -q 'lava.*seat0'; then
			echo "Session found, waiting 10s for services to settle..."
			sleep 10
			sudo bash -c "
				rm -f '$CONF_DIR/99-autologin.conf' \
				      '$PAM_DIR/plasmalogin' \
				      '$PAM_DIR/plasmalogin-autologin' \
				      '$PAM_DIR/plasmalogin-greeter'
			"
			echo "Session started. Cleaned up."
			exit 0
	fi

		sleep 1
	done
	sudo bash -c "
		rm -f '$CONF_DIR/99-autologin.conf' \
		      '$PAM_DIR/plasmalogin' \
		      '$PAM_DIR/plasmalogin-autologin' \
		      '$PAM_DIR/plasmalogin-greeter'
	"
	echo "Timed out waiting for session. Cleaned up." >&2
	exit 1

