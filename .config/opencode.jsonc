{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-autodiscover"],
  "provider": {
    "openai": {
      "name": "Bifrost",
      "options": {
        "baseURL": "https://ai.delnegend.com",
        "apiKey": "{env:BIFROST_API_KEY}"
      }
    }
  },
  "mcp": {
    "browser": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp", "--cdp-endpoint", "ws://localhost:9222"],
      "enabled": true
    }
  }
}
